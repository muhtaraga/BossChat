# Veritabanı: SQLite (sıfır kurulum) veya PostgreSQL (docker compose up -d)
# DATABASE_URL=file:./data/bosschat.db
DATABASE_URL=postgres://bosschat:bosschat@localhost:5433/bosschat
JWT_SECRET=change-me
PORT=3000
OTP_PROVIDER=console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Web Push — üretmek için: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
